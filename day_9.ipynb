   "source": [
    "import pandas as pd\n",
    "\n",
    "data = {\n",
    "    'Name':['Ali', 'Sara', 'Muhammad Tariq', 'Ayesha'],\n",
    "'Score':[85, 92, 100, 78]\n",
    "}\n",
    "df= pd.DataFrame(data)\n",
    "\n",
    "# Day 9: Add Grade column using lamba\n",
    "df['Grade'] = df['Score'].apply(lambda x:\n",
    "'A' if x >=90 else 'B')\n",
    "\n",
    "df"
   ]
